# ============================================
# MAUTRADE — Production Environment Template
# ============================================
# Copy this file to .env.production on your VPS
# and fill in the actual values.
#
# Location on VPS: ~/Mautrade/.env.production
# ============================================

# ── App ──
APP_ENV=production
DOMAIN=mautrade.com

# ── SSL (Let's Encrypt) ──
# Email untuk notifikasi SSL certificate expiry
CERTBOT_EMAIL=admin@mautrade.com

# ── Database ──
DB_USER=mautrade
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_NAME=mautrade

# ── Go API ──
# DATABASE_URL is constructed automatically in docker-compose.prod.yml
# These are used directly by the Go API container:
GAS_FEE_SHARE_RATE=0.5
DEFAULT_CURRENCY=USDT
GAS_FEE_DEPOSIT_ADDRESS=MAUTRADE-USDT-DEPOSIT-PENDING
EXCHANGE_CREDENTIAL_KEY=CHANGE_THIS_GENERATE_WITH_openssl_rand_hex_32
ALLOWED_CORS_ORIGIN=https://mautrade.com
SHUTDOWN_TIMEOUT_SECONDS=15
AUTH_SESSION_TTL_HOURS=720
EMAIL_OTP_TTL_MINUTES=10

# ── Admin Bootstrap (first deploy only) ──
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Mautrade Super Admin
ADMIN_BOOTSTRAP_ROLE=super_admin
